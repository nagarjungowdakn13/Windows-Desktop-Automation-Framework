# Copy to .env and edit. All variables are prefixed with WDA_.

# --- Server ---------------------------------------------------------------
WDA_HOST=127.0.0.1
WDA_PORT=8000
WDA_API_BASE_URL=http://127.0.0.1:8000

# --- Storage --------------------------------------------------------------
# WDA_DATA_DIR=./data
# WDA_LOG_DIR=./logs
# WDA_SCREENSHOT_DIR=./screenshots
# WDA_DATABASE_URL=sqlite:///./data/automation.db

# --- Automation defaults --------------------------------------------------
WDA_DEFAULT_STEP_RETRIES=2
WDA_DEFAULT_RETRY_DELAY_SEC=1.0
WDA_PYAUTOGUI_PAUSE_SEC=0.1
WDA_PYAUTOGUI_FAILSAFE=true

# --- Worker ---------------------------------------------------------------
WDA_WORKER_QUEUE_SIZE=128
